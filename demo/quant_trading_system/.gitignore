# 注意：以下文件应该被版本控制
# !alembic/versions/*.py  # Alembic迁移文件
# !requirements.txt      # 依赖文件
# !docker-compose.yml    # Docker编排文件
# !Dockerfile           # Docker构建文件
# !README.md            # 项目说明文档
# !src/                 # 源代码目录
# !tests/               # 测试文件目录
# !database/            # 数据库脚本目录
# !doc/                 # 文档目录
