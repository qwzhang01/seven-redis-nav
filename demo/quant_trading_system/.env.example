# 量化交易系统环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME="量化交易系统"
APP_VERSION="1.0.0"
DEBUG=true
HOST="0.0.0.0"
PORT=8000

# 数据库配置
DATABASE_URL="postgresql://quant_user:quant_password@localhost:5432/quant_trading"

# JWT配置
JWT_SECRET_KEY="your-secret-key-change-in-production"

# 交易所API配置 - 必须配置才能正常启动实时行情订阅
BINANCE_API_KEY="your-binance-api-key-here"
BINANCE_SECRET_KEY="your-binance-secret-key-here"
BINANCE_TESTNET=true

# 其他可选配置
OKX_API_KEY=""
OKX_SECRET_KEY=""
OKX_PASSPHRASE=""

# 环境标识
ENVIRONMENT="development"

# ===========================================
# 应用配置
# ===========================================

# 应用名称
APP_NAME=量化交易系统

# 应用版本
APP_VERSION=1.0.0

# 调试模式 (开发环境设为True，生产环境设为False)
DEBUG=True

# 服务监听地址
HOST=0.0.0.0

# 服务监听端口
PORT=8000

# 运行环境 (development/testing/production)
ENVIRONMENT=development

# ===========================================
# 数据库配置
# ===========================================

# PostgreSQL数据库连接URL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://quant_user:quant_password@localhost:5432/quant_trading

# 数据库连接池大小
DATABASE_POOL_SIZE=20

# 数据库连接池最大溢出数
DATABASE_MAX_OVERFLOW=30

# 数据库连接回收时间（秒）
DATABASE_POOL_RECYCLE=3600

# ===========================================
# JWT认证配置
# ===========================================

# JWT密钥（生产环境必须修改为强密钥）
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production

# JWT算法
JWT_ALGORITHM=HS256

# JWT令牌过期时间（分钟）
JWT_EXPIRE_MINUTES=30

# JWT刷新令牌过期时间（天）
JWT_REFRESH_EXPIRE_DAYS=7

# ===========================================
# CORS跨域配置
# ===========================================

# CORS允许的来源（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# 密码安全配置
# ===========================================

# 密码最小长度
PASSWORD_MIN_LENGTH=6

# 密码哈希轮数
PASSWORD_HASH_ROUNDS=12

# ===========================================
# 邮件服务配置（用于密码重置）
# ===========================================

# SMTP服务器地址
SMTP_SERVER=smtp.gmail.com

# SMTP端口
SMTP_PORT=587

# SMTP用户名
SMTP_USERNAME=your-email@gmail.com

# SMTP密码（应用专用密码）
SMTP_PASSWORD=your-app-password

# 是否使用TLS
SMTP_USE_TLS=True

# ===========================================
# Redis缓存配置
# ===========================================

# Redis连接URL
REDIS_URL=redis://localhost:6379/0

# Redis密码（如有）
REDIS_PASSWORD=

# Redis数据库编号
REDIS_DB=0

# ===========================================
# 日志配置
# ===========================================

# 日志级别 (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=/var/log/quant_trading.log

# ===========================================
# 安全配置
# ===========================================

# 允许访问的主机（逗号分隔）
ALLOWED_HOSTS=localhost,127.0.0.1

# 速率限制：每分钟最大请求数
RATE_LIMIT_REQUESTS=100

# 速率限制窗口（秒）
RATE_LIMIT_WINDOW=60

# ===========================================
# API配置
# ===========================================

# API前缀
API_PREFIX=/api/v1

# 文档URL
DOCS_URL=/docs

# ReDoc文档URL
REDOC_URL=/redoc

# ===========================================
# 交易所API配置
# ===========================================

# 交易所API请求超时时间（秒）
EXCHANGE_API_TIMEOUT=30

# 交易所API重试次数
EXCHANGE_API_RETRY_COUNT=3

# 交易所API速率限制（每秒请求数）
EXCHANGE_API_RATE_LIMIT=10

# ===========================================
# 文件上传配置
# ===========================================

# 最大文件大小（字节）
MAX_FILE_SIZE=10485760

# 允许的文件类型（逗号分隔）
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif

# 文件上传目录
UPLOAD_DIR=/var/uploads

# ===========================================
# 监控配置
# ===========================================

# 是否启用监控指标
ENABLE_METRICS=True

# 监控指标端口
METRICS_PORT=9090

# 健康检查间隔（秒）
HEALTH_CHECK_INTERVAL=30

# ===========================================
# 测试配置
# ===========================================

# 测试数据库URL
TEST_DATABASE_URL=sqlite:///./test.db

# 测试模式
TEST_MODE=False

# ===========================================
# 生产环境专用配置
# ===========================================

# 生产环境数据库URL（覆盖DATABASE_URL）
# DATABASE_URL=postgresql://prod_user:prod_password@prod-db.example.com:5432/quant_trading_prod

# 生产环境JWT密钥（必须修改）
# JWT_SECRET_KEY=your-production-super-secret-key

# 生产环境CORS配置
# CORS_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# 生产环境日志级别
# LOG_LEVEL=WARNING

# 生产环境Redis配置
# REDIS_URL=redis://redis-server.example.com:6379/0

# ===========================================
# 高级配置（一般无需修改）
# ===========================================

# SQLAlchemy连接池预Ping
SQLALCHEMY_POOL_PRE_PING=True

# SQLAlchemy连接池回收
SQLALCHEMY_POOL_RECYCLE=3600

# SQLAlchemy连接池大小
SQLALCHEMY_POOL_SIZE=10

# SQLAlchemy最大溢出连接数
SQLALCHEMY_MAX_OVERFLOW=20

# ===========================================
# 使用说明
# ===========================================

# 1. 复制此文件为 .env
#    cp .env.example .env

# 2. 根据实际环境修改配置
#    - 开发环境：主要修改数据库连接和邮件配置
#    - 生产环境：必须修改JWT密钥、数据库连接、Redis配置等

# 3. 确保 .env 文件不被提交到版本控制
#    在 .gitignore 中添加 .env

# 4. 敏感信息（密码、密钥等）建议使用环境变量或密钥管理服务

# 5. 生产环境建议使用：
#    - 强密码和密钥
#    - HTTPS加密传输
#    - 防火墙和访问控制
#    - 定期备份和监控

# 交易所 API - Binance
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_TESTNET=true

# 交易所 API - OKX
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 数据源配置
DATA_PROVIDER=binance
HISTORICAL_DATA_PATH=./data/historical

# 回测配置
BACKTEST_START_DATE=2024-01-01
BACKTEST_END_DATE=2024-12-31
INITIAL_CAPITAL=100000

# 风控配置
MAX_POSITION_SIZE=0.1
MAX_DRAWDOWN=0.2
STOP_LOSS_PCT=0.02

# 通知配置
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
