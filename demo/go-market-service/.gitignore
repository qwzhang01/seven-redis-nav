# ====================
# Go 项目 .gitignore
# ====================

# 二进制文件
*.exe
*.exe~
*.dll
*.so
*.dylib
/bin/
/build/
/dist/

# 测试相关
*.test
*.out
coverage.txt
coverage.html
*.coverprofile

# 依赖目录
/vendor/

# IDE 和编辑器
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 日志文件
*.log
logs/
/log/

# 配置文件（敏感信息）
configs/config.local.yaml
configs/*.local.yaml
*.env
.env
.env.*
!.env.example

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 临时文件
tmp/
temp/
*.tmp
*.temp
*.bak

# 调试文件
debug
__debug_bin*

# Air 热重载
/tmp/

# 性能分析
*.pprof
*.prof
cpu.out
mem.out

# 文档生成
/docs/api/

# 本地脚本
scripts/*.local.sh

# 密钥和证书
*.pem
*.key
*.crt
*.p12
secrets/
