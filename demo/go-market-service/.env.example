# ====================
# Go Market Service 环境变量示例
# ====================
# 复制此文件为 .env 并填入实际值

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
GIN_MODE=release

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=market_service

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 交易所 API (Binance)
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here
BINANCE_TESTNET=true

# 交易所 API (OKX)
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# WebSocket 配置
WS_PING_INTERVAL=30s
WS_PONG_TIMEOUT=10s
