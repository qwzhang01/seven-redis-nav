# ========================================
# Quant Meta 环境变量配置
# ========================================

# 应用配置
NODE_ENV=production
VERSION=latest

# Docker 配置
IMAGE_NAME=quantmeta
IMAGE_TAG=latest
CONTAINER_NAME=quantmeta

# 端口配置
HOST_PORT=80

# 时区配置
TZ=Asia/Shanghai

# 资源限制
MEMORY_LIMIT=1G
CPU_LIMIT=2
MEMORY_RESERVATION=256M
CPU_RESERVATION=0.5

# 日志配置
LOG_MAX_SIZE=10m
LOG_MAX_FILE=3

# 网络配置
NETWORK_SUBNET=172.28.0.0/16

# API 配置
# 生产环境使用空字符串，让前端使用相对路径，通过 NGINX 反向代理
VITE_API_BASE_URL=
