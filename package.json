{
  "name": "seven-redis-nav",
  "version": "0.1.0",
  "private": false,
  "license": "MIT",
  "type": "module",
  "description": "Seven Redis Nav — A lightweight macOS native Redis management tool built with Tauri 2 + Vue 3 + Rust",
  "author": "avinzhang",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwzhang01/seven-redis-nav.git"
  },
  "bugs": {
    "url": "https://github.com/qwzhang01/seven-redis-nav/issues"
  },
  "homepage": "https://github.com/qwzhang01/seven-redis-nav#readme",
  "keywords": [
    "redis",
    "redis-gui",
    "redis-manager",
    "redis-client",
    "tauri",
    "vue3",
    "rust",
    "macos",
    "database-tool"
  ],
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src --ext .ts,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "typecheck": "vue-tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && cd src-tauri && cargo fmt --check && cargo clippy -- -D warnings",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@tanstack/vue-virtual": "^3.13.24",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-opener": "^2",
    "@types/uuid": "^11.0.0",
    "codemirror": "^6.0.2",
    "echarts": "^6.0.0",
    "file-saver": "^2.0.5",
    "pinia": "^2.3.0",
    "remixicon": "^4.6.0",
    "tdesign-vue-next": "1.10.5",
    "uuid": "^14.0.0",
    "vue": "^3.5.13",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tauri-apps/cli": "2.11.0",
    "@types/file-saver": "^2.0.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.0.7",
    "@vitest/ui": "^3.0.7",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^26.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^3.0.7",
    "vue-tsc": "^2.1.10"
  }
}
