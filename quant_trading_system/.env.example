# ====================
# 量化交易系统环境变量示例
# ====================
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=量化交易系统
APP_VERSION=1.0.0
DEBUG=False
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# 数据库配置
DATABASE_URL=postgresql://postgres:pwd@ip:port/quant_trading
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_RECYCLE=3600
SQLALCHEMY_POOL_PRE_PING=True
SQLALCHEMY_POOL_RECYCLE=3600
SQLALCHEMY_POOL_SIZE=20
SQLALCHEMY_MAX_OVERFLOW=30
INIT_TABLE=true

# ===== Redis 配置（接入已有 redis 容器）=====
REDIS_URL=redis://:pwd@redis:6379/0
REDIS_PASSWORD=
REDIS_DB=0

# ===== Kafka 配置（接入已有 kafka 容器）=====
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ===== MinIO 配置（接入已有 minio 容器）=====
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=pwd
MINIO_SECURE=False

# ===== JWT 认证配置 =====
# 生成命令: openssl rand -hex 64
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ===== 日志配置 =====
LOG_LEVEL=INFO
LOG_FILE=./logs/quant_trading.log

# ===== 安全配置 =====
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000,*
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_ROUNDS=12

# ===== API 配置 =====
API_PREFIX=/api/v1
# 生产环境关闭 Swagger UI 和 ReDoc（留空即关闭）
DOCS_URL=
REDOC_URL=

# ===== 交易所 API =====
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ===== 代理配置（开发环境可选）=====
# 支持 http 和 socks5 代理，留空则不使用代理
# 格式示例:
#   http://127.0.0.1:7890
#   socks5://127.0.0.1:7891
PROXY_URL=

# ===== 监控配置 =====
ENABLE_METRICS=True
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ===== 通知配置（可选）=====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 通知配置（可选）=====
SYNC_HISTORY_DATA=False
SYNC_HISTORY_DATA_START_DATE="2022-01-01 00:00:00"
